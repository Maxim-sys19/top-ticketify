{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "incremental": true,
    "tsBuildInfoFile": "./dist/tsconfig.build.tsbuildinfo",
    "declaration": true,
    "sourceMap": true,
    "removeComments": true
  },
  "exclude": ["node_modules", "**/*.spec.ts", "test/**/*", "dist"]
}
